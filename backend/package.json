{
  "name": "focus-builder-backend",
  "version": "1.0.0",
  "description": "Backend API for Pomodoro Focus Builder",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "node -r ts-node/register src/database/migrate.ts",
    "db:add-column": "node -r ts-node/register src/database/add-actual-duration.ts",
    "db:convert-seconds": "node -r ts-node/register src/database/convert-to-seconds.ts",
    "db:seed": "node -r ts-node/register src/database/seed-mock-data.ts"
  },
  "keywords": ["pomodoro", "focus", "timer"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.3",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2"
  }
}
